# InpxWebReader remote Linux build machine.
# Copy this file to .env. The real .env is ignored by Git.
# The password is used for both SSH authentication and sudo. Leave it empty
# only when SSH authentication is configured separately and sudo is passwordless.

INPX_WEB_READER_BUILD_HOST=192.168.1.50
INPX_WEB_READER_BUILD_USER=inpx-web-reader-build
INPX_WEB_READER_BUILD_PASSWORD=
INPX_WEB_READER_BUILD_WORKDIR=/home/inpx-web-reader-build/inpx-web-reader-remote
