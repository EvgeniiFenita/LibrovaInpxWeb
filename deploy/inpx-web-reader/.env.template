# Copy this file to deploy/inpx-web-reader/.env and adjust host paths.
# Build the image before starting Compose:
# docker build -f deploy/inpx-web-reader/Dockerfile -t inpx-web-reader:latest .

INPX_WEB_READER_IMAGE=inpx-web-reader:latest
INPX_WEB_READER_HOST_PORT=8080

# Host paths visible to Docker. The INPX source is mounted read-only.
INPX_WEB_READER_SOURCE_PATH=/absolute/path/to/inpx-source
INPX_WEB_READER_DATA_PATH=/absolute/path/to/inpx-web-reader-data

# Optional absolute paths inside the container when auto-detection is insufficient.
# Both paths must resolve under the read-only /source mount, for example
# /source/catalog.inpx and /source/lib.rus.ec.
INPX_WEB_READER_INPX_PATH=
INPX_WEB_READER_ARCHIVE_ROOT=

# Optional executable path inside the container. Add or mount fbc through a
# Compose override before setting this value; a host path is not accepted here.
INPX_WEB_READER_CONVERTER_PATH=

# Required for LAN deployment. Store the access password in this file, not in .env.
INPX_WEB_READER_AUTH_TOKEN_FILE=/absolute/path/to/inpx-web-reader-auth-token.txt

# Server records are written to Docker stderr and /data/runtime/Logs.
INPX_WEB_READER_LOG_LEVEL=info
INPX_WEB_READER_LOG_MAX_FILE_SIZE_MIB=20
INPX_WEB_READER_LOG_MAX_ROTATED_FILES=4

INPX_WEB_READER_MAX_HTTP_THREADS=4
INPX_WEB_READER_MAX_HTTP_QUEUED_REQUESTS=32
INPX_WEB_READER_MAX_BACKEND_QUEUE_DEPTH=64
INPX_WEB_READER_MAX_SCAN_WORKERS=4
INPX_WEB_READER_MAX_CONCURRENT_DOWNLOADS=2
INPX_WEB_READER_MAX_REQUEST_BODY_BYTES=65536
INPX_WEB_READER_HTTP_READ_TIMEOUT_MS=15000
INPX_WEB_READER_HTTP_WRITE_TIMEOUT_MS=30000
INPX_WEB_READER_MAX_COVER_CACHE_MIB=128
INPX_WEB_READER_MAX_STEADY_STATE_MEMORY_MIB=1024
INPX_WEB_READER_MAX_PAGE_SIZE=200
